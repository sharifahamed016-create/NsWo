{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "A registered member of NSWO",
      "type": "object",
      "properties": {
        "memberId": { "type": "string", "description": "Custom identity like NSWO-001" },
        "name": { "type": "string" },
        "nameBn": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "joinedDate": { "type": "string", "format": "date" },
        "balance": { "type": "number" },
        "totalPaid": { "type": "number" },
        "totalDue": { "type": "number" },
        "includeInMonthlyLedger": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["memberId", "name", "nameBn", "phone", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A financial contribution from a member",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "memberName": { "type": "string" },
        "memberNameBn": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "month": { "type": "string" },
        "year": { "type": "number" },
        "type": { "type": "string" },
        "receiptNo": { "type": "string" },
        "method": { "type": "string" },
        "remarks": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["memberId", "amount", "date", "receiptNo"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Expenditure by the organization",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "requestedBy": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["amount", "date", "category"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global configuration for the application",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "nameBn": { "type": "string" },
        "logoURL": { "type": "string" },
        "contactPhone": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "nameBn"]
    },
    "ArchiveItem": {
      "title": "ArchiveItem",
      "description": "A digital archive doc representing old reports, memos or images",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "titleBn": { "type": "string" },
        "description": { "type": "string" },
        "descriptionBn": { "type": "string" },
        "category": { "type": "string", "enum": ["report", "photo", "document"] },
        "date": { "type": "string", "format": "date" },
        "url": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "titleBn", "category", "date"]
    },
    "CommitteeMember": {
      "title": "CommitteeMember",
      "description": "A member representing official positions in active administrative term",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "name": { "type": "string" },
        "nameBn": { "type": "string" },
        "role": { "type": "string" },
        "roleBn": { "type": "string" },
        "termYears": { "type": "string" },
        "weightRank": { "type": "number" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "nameBn", "role", "roleBn", "termYears"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Private direct chat message or department/branch discussion room log",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverId": { "type": "string" },
        "roomType": { "type": "string", "enum": ["direct", "group"] },
        "roomCategory": { "type": "string" },
        "text": { "type": "string" },
        "voiceURL": { "type": "string" },
        "duration": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["senderId", "senderName", "roomType", "roomCategory", "createdAt"]
    }
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Collection of all members"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Collection of all payment transactions"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Collection of all organization expenses"
    },
    "/settings/config": {
      "schema": "AppSettings",
      "description": "Global application configuration"
    },
    "/digital_archive/{archiveId}": {
      "schema": "ArchiveItem",
      "description": "Digital Archive items of meetings, certificates, other records"
    },
    "/committee_members/{committeeMemberId}": {
      "schema": "CommitteeMember",
      "description": "Administrative official designations"
    },
    "/chat_messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Internal and department discussion board messages"
    }
  }
}
